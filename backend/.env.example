SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Optional: a JWT with a restricted DB role for app queries (see docs/schema.sql)
# Falls back to SUPABASE_SERVICE_KEY if not set.
SUPABASE_LIMITED_KEY=

SUPABASE_ANON_KEY=your_supabase_anon_key
OPENAI_API_KEY=your_openai_api_key

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET=your_app_secret

# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# Max upload file size in MB (default 100)
MAX_UPLOAD_SIZE_MB=100

# Max number of CSV columns allowed (default 200)
MAX_CSV_COLUMNS=200
