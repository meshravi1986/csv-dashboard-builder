{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": null,
    "nixpacksConfigPath": "backend",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "name": "python"
        }
      }
    }
  },
  "deploy": {
    "startCommand": "python -m uvicorn app.main:app --host 0.0.0.0 --port $PORT"
  }
}